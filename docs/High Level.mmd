        QRY --> EMB2[Embedder] --> RTV[Retriever] --> RNK[Reranker] --> GEN[LLM]
        GEN --> RES([Response])
    end

    subgraph Data Layer
        DB[(Qdrant)]
        EMB -- upsert --> DB
        RTV -- hybrid search --> DB
    end